{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../.vercel/output/functions/api",
    "paths": {
      "@workspace/db": ["../lib/db/src/index.ts"],
      "@workspace/db/schema": ["../lib/db/src/schema/index.ts"],
      "@workspace/api-zod": ["../lib/api-zod/src/index.ts"],
      "@workspace/api-spec": ["../lib/api-spec/src/index.ts"]
    }
  },
  "include": [
    "./**/*.ts",
    "../artifacts/api-server/src/**/*.ts",
    "../lib/db/src/**/*.ts",
    "../lib/api-zod/src/**/*.ts"
  ],
  "exclude": ["node_modules", "../artifacts/web"]
}
