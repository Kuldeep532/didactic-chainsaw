# ============================================================
# Nexus Wave Technologies — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Add .env to .gitignore.

# ── Database ───────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/nexuswave

# ── Authentication ─────────────────────────────────────────
# JWT signing secret — use a long random string (min 32 chars)
SESSION_SECRET=change-this-to-a-long-random-secret

# ── Google OAuth (optional) ────────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
# Required for "Continue with Google" on web
GOOGLE_WEB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── AI Providers (at least one required for Nexus Mitra) ──
# Gemini (recommended — free tier available)
GEMINI_API_KEY=your-gemini-api-key

# Gemini model overrides (optional — defaults shown)
# GEMINI_CHAT_MODEL=gemini-1.5-flash
# GEMINI_EMBED_MODEL=text-embedding-004

# OpenAI (optional — fallback provider)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Mobile App Security (optional) ─────────────────────────
# SHA-256 fingerprint of the Android signing certificate
ANDROID_CERTIFICATE_FINGERPRINT=71:9A:03:D5:60:DE:9E:BE:2D:40:79:E5:18:6D:32:E1:54:A0:AD:6C:02:E0:F3:43:32:07:94:BE:EF:E8:BF:EC

# ── Admin Setup ─────────────────────────────────────────────
# There is no default admin password. After running the first migration,
# manually set isAdmin=true for your user account in the database:
#   UPDATE users SET is_admin = true WHERE email = 'your@email.com';
