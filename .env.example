# ============================================================
# Nexus Wave Technologies — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Add .env to .gitignore.
#
# The platform is environment-agnostic. All values are read from
# process.env so the same codebase runs on Replit, Vercel, Netlify,
# or any other serverless host without code changes.

# ── Single Backend URL ───────────────────────────────────────
# All clients (Website + Nexus Plus + Geeta Nexus) must point to
# this same production URL. Mobile apps read it via Remote Config.
# VITE_BASE_URL is the same value but exposed to the browser (no trailing slash).
BASE_URL=https://your-domain.vercel.app
VITE_BASE_URL=https://your-domain.vercel.app

# ── Database ───────────────────────────────────────────────
# PostgreSQL connection string (runtime-managed on Replit)
DATABASE_URL=postgresql://user:password@host:5432/nexuswave

# ── Firebase Authentication (required) ───────────────────────
# Web client config (must be exposed to the browser)
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend Firebase Admin SDK.
# Option A: paste the entire service-account JSON on one line.
FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B (if you prefer separate variables).
# If FIREBASE_ADMIN_SERVICE_ACCOUNT is set, these are ignored.
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
# Comma-separated UIDs that receive the `admin: true` Firebase custom claim.
# Optional: if omitted, admins can still be promoted from the admin panel once
# at least one admin exists.
FIREBASE_ADMIN_UIDS=uid1,uid2

# One-time setup key for bootstrapping the first admin without a DB record.
# Set once, use it, then rotate or remove it.
FIREBASE_ADMIN_SETUP_KEY=change-me-to-a-long-random-string

# ── Google Sign-In (deprecated, now handled by Firebase Auth) ──
# Leave empty unless you specifically need a standalone Google OAuth client.
GOOGLE_WEB_CLIENT_ID=

# ── AI Providers (at least one required for Nexus Mitra) ──
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── Dynamic API Proxy Services ───────────────────────────────
# Each service is a JSON string describing the remote endpoint and how secrets
# are injected. Available authType values: bearer, queryKey, header.
# The `secret` field names the environment variable that holds the real key.
API_SERVICE_GEMINI={"baseUrl":"https://generativelanguage.googleapis.com/v1beta","authType":"queryKey","authKeyName":"key","secret":"GEMINI_API_KEY"}
API_SERVICE_OPENAI={"baseUrl":"https://api.openai.com/v1","authType":"bearer","secret":"OPENAI_API_KEY"}
API_SERVICE_GROQ={"baseUrl":"https://api.groq.com/openai/v1","authType":"bearer","secret":"GROQ_API_KEY"}
API_SERVICE_ANTHROPIC={"baseUrl":"https://api.anthropic.com","authType":"header","headerName":"x-api-key","secret":"ANTHROPIC_API_KEY"}

# ── Mobile App Verification ─────────────────────────────────
# SHA-256 fingerprints of Android signing certificates (comma-separated)
ANDROID_CERTIFICATE_FINGERPRINTS=719a03d560de9ebe2d4079e5186d32e154a0ad6c02e0f343320794beefe8bfec

# ── App Version & Update Controls (also served via Remote Config) ───
MINIMUM_SUPPORTED_VERSION=1.0.0
LATEST_VERSION=1.0.0
UPDATE_URL=https://your-domain.vercel.app/apps
MAINTENANCE_MODE=false
