# ============================================================
# Nexus Wave Technologies — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. Add .env to .gitignore.

# ── Single Backend URL ───────────────────────────────────────
# All clients (Website + Nexus Plus app + Geeta Nexus app) must
# use this same production base URL. Configure your mobile apps
# to read this value at build time or via remote config.
BASE_URL=https://your-domain.vercel.app

# ── Database ───────────────────────────────────────────────
# PostgreSQL connection string (runtime-managed on Replit)
DATABASE_URL=postgresql://user:password@host:5432/nexuswave

# ── Firebase Authentication (required) ───────────────────────
# Web client Firebase config — exposed to the browser via VITE_ prefix
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Backend Firebase Admin SDK service account (private JSON, minified)
# Set this as a single-line JSON string.
FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ── Firebase Remote Config / Admin Custom Claims ─────────────
# Comma-separated list of Firebase UIDs that should be treated as admins.
# These users get the `admin: true` custom claim when signing in.
FIREBASE_ADMIN_UIDS=uid1,uid2

# ── Google Sign-In (optional, only if using standalone Google OAuth) ─
GOOGLE_WEB_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── AI Providers (at least one required for Nexus Mitra) ──
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── Payment Providers (configure only the ones you use) ──────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key

# ── Dynamic API Proxy Services ───────────────────────────────
# Each API_SERVICE_* value is a JSON object describing a remote service.
# Secrets are stored here and never exposed to clients.
# Example:
# API_SERVICE_GEMINI={"baseUrl":"https://generativelanguage.googleapis.com","authType":"queryKey","authKeyName":"key","secret":"GEMINI_API_KEY"}
# API_SERVICE_OPENAI={"baseUrl":"https://api.openai.com","authType":"bearer","secret":"OPENAI_API_KEY"}
# API_SERVICE_GROQ={"baseUrl":"https://api.groq.com/openai/v1","authType":"bearer","secret":"GROQ_API_KEY"}
# API_SERVICE_ANTHROPIC={"baseUrl":"https://api.anthropic.com","authType":"header","headerName":"x-api-key","secret":"ANTHROPIC_API_KEY"}

# ── Mobile App Verification ─────────────────────────────────
# SHA-256 fingerprints of Android signing certificates (comma-separated)
ANDROID_CERTIFICATE_FINGERPRINTS=719a03d560de9ebe2d4079e5186d32e154a0ad6c02e0f343320794beefe8bfec

# ── App Version & Update Controls (also via Remote Config) ───
# MINIMUM_SUPPORTED_VERSION=1.0.0
# LATEST_VERSION=1.0.0
# UPDATE_URL=https://your-domain.vercel.app/apps
# MAINTENANCE_MODE=false
