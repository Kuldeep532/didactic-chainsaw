{
  "version": 2,
  "buildCommand": "pnpm -w run typecheck:libs && pnpm --filter @workspace/web run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/web/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "artifacts/api-server/src/**,lib/db/src/**,lib/api-zod/src/**,lib/api-spec/src/**"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
